{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ImageBuilderServiceLinkedRole",
      "Effect": "Allow",
      "Action": "iam:CreateServiceLinkedRole",
      "Resource": "arn:aws:iam::882434014807:role/aws-service-role/imagebuilder.amazonaws.com/AWSServiceRoleForImageBuilder",
      "Condition": {
        "StringEquals": {
          "iam:AWSServiceName": "imagebuilder.amazonaws.com"
        }
      }
    }
  ]
}
